{
  "name": "codelink-extension",
  "displayName": "CodeLink",
  "version": "0.1.0",
  "publisher": "codelink",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "*"
  ],
  "contributes": {
    "commands": [
      {
        "command": "codelink.hello",
        "title": "CodeLink: Hello World"
      },
      {
        "command": "codelink.listKiroCommands",
        "title": "CodeLink: List Kiro Commands"
      }
    ]
  },
  "configuration": {
    "title": "CodeLink",
    "properties": {
      "codelink.relayServerUrl": {
        "type": "string",
        "default": "http://localhost:8080",
        "description": "URL of the CodeLink Relay Server"
      }
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@codelink/protocol": "*",
    "simple-git": "^3.25.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.18"
  }
}
