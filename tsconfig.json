{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "types": ["vitest/globals", "node"],
    "paths": {
      "@testing-library/react-native": [
        "./node_modules/@testing-library/react-native/build/index.d.ts"
      ]
    }
  },
  "include": [
    "tests/**/*",
    "vitest.config.ts",
    "packages/protocol/src/**/*",
    "packages/relay-server/src/**/*",
    "packages/vscode-extension/src/**/*"
  ],
  "exclude": ["node_modules/@testing-library/react-native/src"]
}
